CODE1: Ajax jvar => 'configs.collections.bootstrap', type => 'json', file => 'api-dashboard-bootstrap', code => q{
  use Developer::Dashboard::Folder ();
  use Developer::Dashboard::DataHelper qw(j je);

  my $dir = Developer::Dashboard::Folder->postman;
  my @collections;
  my @errors;

  if ( defined $dir && $dir ne '' && -d $dir ) {
    my $dh;
    if ( !opendir( $dh, $dir ) ) {
      push @errors, "Unable to read Postman collection directory $dir: $!";
      print j { collections => \@collections, errors => \@errors };
      return;
    }
    for my $entry ( sort readdir $dh ) {
      next if $entry eq '.' || $entry eq '..';
      next if $entry !~ /\.json\z/i;
      my $path = "$dir/$entry";
      next if !-f $path;
      my $fh;
      if ( !open( $fh, '<', $path ) ) {
        push @errors, "Unable to read $path: $!";
        next;
      }
      local $/;
      my $raw = <$fh>;
      close $fh or push @errors, "Unable to close $path: $!";
      my $parsed = eval { je $raw };
      if ($@ || ref($parsed) ne 'HASH') {
        push @errors, "Unable to parse Postman JSON in $entry";
        next;
      }
      my $collection = ref( $parsed->{collection} ) eq 'HASH' ? $parsed->{collection} : $parsed;
      if ( ref($collection) ne 'HASH' || ref( $collection->{info} ) ne 'HASH' || !( $collection->{info}{name} || '' ) ) {
        push @errors, "Skipping $entry because it does not contain a Postman collection";
        next;
      }
      push @collections, $collection;
    }
    closedir $dh or push @errors, "Unable to close Postman collection directory $dir: $!";
  }

  print j {
    collections => \@collections,
    errors      => \@errors,
  };
};
