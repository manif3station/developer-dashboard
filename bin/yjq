#!/usr/bin/env perl

use strict;
use warnings;

use FindBin qw($Bin);
use lib "$Bin/../lib";

use Developer::Dashboard::CLI::Query qw(run_query_command);

# main(@ARGV)
# Runs the standalone YAML query executable.
# Input: command-line arguments from @ARGV and optional STDIN.
# Output: prints the selected YAML value, then exits.
run_query_command( command => 'yjq', args => \@ARGV );

__END__

=pod

=head1 NAME

yjq - standalone YAML query command for Developer Dashboard

=head1 SYNOPSIS

  yjq [path] [file]

=head1 DESCRIPTION

This is the lightweight standalone executable behind C<dashboard yjq>.

=cut
